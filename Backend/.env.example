# Copy this file to `.env` for local development. Never commit the real `.env`.

# Rakuten Web Service credentials (https://webservice.rakuten.co.jp/)
RAKUTEN_APPLICATION_ID=
RAKUTEN_AFFILIATE_ID=

# Shared secret the iOS app must send as the `X-API-Key` header on every
# request to /v1/*. Generate with: openssl rand -hex 32
API_KEY=

# Optional, defaults to 8080
PORT=8080
